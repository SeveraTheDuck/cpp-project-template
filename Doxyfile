PROJECT_NAME           = "C++23 Template Project"
OUTPUT_DIRECTORY       = docs_output
INPUT                  = source/ README.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
OPTIMIZE_OUTPUT_FOR_C  = NO

EXTENSION_MAPPING      = hpp=C++
FILE_PATTERNS          = *.cpp *.hpp *.h

HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome.css
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
GENERATE_LEGEND        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

GENERATE_LATEX         = NO
GENERATE_HTML          = YES
